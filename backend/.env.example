PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/tadpole
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
WEBHOOK_SECRET=
FRONTEND_ORIGIN=http://localhost:5173

# Optional: for npm run create-admin (defaults: admin@tadpole.local / admin123)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password

# Phase 4: observability (optional)
# SLOW_REQUEST_MS=500
# SLOW_QUERY_MS=200
# Production: set FRONTEND_ORIGIN to your frontend URL (e.g. https://app.example.com). Run backend behind HTTPS (e.g. Nginx) and set x-forwarded-proto so HTTPS redirect works.
